generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  AGENT_CLIENT
  N1_CLIENT
  AGENT_COMMERCIAL
  SERVICE_ACHAT
}

enum TypeVehicule {
  CAMION
  REMORQUE
  TOURISME
}

enum TypeCommande {
  INSPECTION  // Avec inspection physique
  DIRECTE     // Commande directe sans inspection
}

enum StatutCommande {
  // ── Flux inspection ──────────────────────────────────────────────
  DEMANDE_INSPECTION        // Agent client crée la demande d'inspection
  INSPECTION_EN_COURS       // Commercial prend en charge
  INSPECTION_ENVOYEE        // Commercial envoie la fiche par mail
  DEVIS_DEMANDE             // Agent client saisit ses besoins (après double validation)
  // ── Flux commande directe ────────────────────────────────────────
  COMMANDE_DIRECTE          // Agent client crée commande directe (véhicule + besoins)
  VALIDATION_N1             // En attente validation N+1
  // ── Flux commun (devis → montage) ────────────────────────────────
  DEVIS_EN_COURS            // Commercial saisit marques dispo + prix HT
  DEVIS_PROPOSE             // Agent client choisit (inspection) / N+1 valide devis (directe)
  VALIDEE                   // Validée → Service achat passe commande
  COMMANDEE_FOURNISSEUR     // Commande passée fournisseur
  PNEUS_LIVRES              // Pneus arrivés au point de montage
  MONTEE                    // Montage effectué
  REJETEE                   // Rejetée
  INSPECTION_TERMINEE       // (conservé pour compatibilité)
  EN_ATTENTE_VALIDATION     // (conservé pour compatibilité)
}

model Entreprise {
  id           String        @id @default(cuid())
  nom          String
  adresse      String?
  telephone    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  utilisateurs Utilisateur[]
  commandes    Commande[]
}

model Utilisateur {
  id           String      @id @default(cuid())
  nom          String
  prenom       String
  email        String      @unique
  code         String
  role         Role
  actif        Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  entrepriseId String?
  entreprise   Entreprise? @relation(fields: [entrepriseId], references: [id])

  commandesCreees     Commande[]   @relation("CommandeCreateur")
  commandesValidees   Commande[]   @relation("CommandeValidateur")
  commandesCommercial Commande[]   @relation("CommandeCommercial")
  commandesAchat      Commande[]   @relation("CommandeAchat")
  historiques         Historique[]
}

model SiteMontage {
  id        String     @id @default(cuid())
  nom       String
  adresse   String
  ville     String
  telephone String?
  actif     Boolean    @default(true)
  createdAt DateTime   @default(now())
  commandes Commande[]
}

model Commande {
  id              String         @id @default(cuid())
  reference       String         @unique
  typeCommande    TypeCommande   @default(INSPECTION)
  statut          StatutCommande @default(DEMANDE_INSPECTION)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Véhicule
  typeVehicule    TypeVehicule
  immatriculation String
  numeroChauffeur String
  villeDepart     String

  // Inspection (rempli par agent commercial)
  dateInspection         DateTime?
  notesInspection        String?
  inspectionValideeAgent Boolean  @default(false)
  inspectionValideeN1    Boolean  @default(false)

  // Demande de l'agent client (marque + dimension + quantité souhaitées)
  marqueDemandee    String?
  dimensionDemandee String?
  quantiteDemandee  Int?
  notesDevis        String?    // Précisions du client

  // Prix total (calculé sur le pneu choisi)
  prixTotal       Float?
  validePrix      Boolean        @default(false)

  // Point de montage (choisi par agent commercial)
  siteMontageId   String?
  siteMontage     SiteMontage?   @relation(fields: [siteMontageId], references: [id])

  // Suivi livraison/montage
  dateLivraison   DateTime?
  dateMontage     DateTime?
  notesMontage    String?

  // Relations
  entrepriseId    String
  entreprise      Entreprise     @relation(fields: [entrepriseId], references: [id])
  createurId      String
  createur        Utilisateur    @relation("CommandeCreateur", fields: [createurId], references: [id])
  validateurId    String?
  validateur      Utilisateur?   @relation("CommandeValidateur", fields: [validateurId], references: [id])
  agentCommercialId String?
  agentCommercial   Utilisateur? @relation("CommandeCommercial", fields: [agentCommercialId], references: [id])
  serviceAchatId  String?
  serviceAchat    Utilisateur?   @relation("CommandeAchat", fields: [serviceAchatId], references: [id])

  pneus           Pneu[]
  historiques     Historique[]
}

model Pneu {
  id           String   @id @default(cuid())
  marque       String
  reference    String?  // Référence produit
  dimension    String
  quantite     Int
  prixUnitaire Float    // Prix HT unitaire
  disponible   Boolean  @default(true)
  choisi       Boolean  @default(false)  // Pneu sélectionné par l'agent client
  notes        String?  // Délai, remarques
  commandeId   String
  commande     Commande @relation(fields: [commandeId], references: [id], onDelete: Cascade)
}

model Historique {
  id            String         @id @default(cuid())
  statut        StatutCommande
  commentaire   String?
  createdAt     DateTime       @default(now())
  commandeId    String
  commande      Commande       @relation(fields: [commandeId], references: [id], onDelete: Cascade)
  utilisateurId String?
  utilisateur   Utilisateur?   @relation(fields: [utilisateurId], references: [id])
}
