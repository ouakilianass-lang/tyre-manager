generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  AGENT_CLIENT
  N1_CLIENT
  AGENT_COMMERCIAL
  SERVICE_ACHAT
}

enum TypeVehicule {
  CAMION
  REMORQUE
  TOURISME
}

enum StatutCommande {
  DEMANDE_INSPECTION        // 1. Agent client crée la demande
  INSPECTION_EN_COURS       // 2. Agent commercial prend en charge
  INSPECTION_ENVOYEE        // 3. Agent commercial envoie la fiche par mail
  DEVIS_DEMANDE             // 4. Agent client + N+1 ont validé → agent client demande les prix
  DEVIS_PROPOSE             // 5. Agent commercial propose marques dispo + prix HT
  EN_ATTENTE_VALIDATION     // 6. N+1 valide le prix
  VALIDEE                   // 7. Validée → Service achat passe commande
  COMMANDEE_FOURNISSEUR     // 8. Commande passée fournisseur
  PNEUS_LIVRES              // 9. Pneus arrivés au point de montage
  MONTEE                    // 10. Montage effectué
  REJETEE                   // Rejetée à n'importe quelle étape
  INSPECTION_TERMINEE       // (conservé pour compatibilité)
}

model Entreprise {
  id           String        @id @default(cuid())
  nom          String
  adresse      String?
  telephone    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  utilisateurs Utilisateur[]
  commandes    Commande[]
}

model Utilisateur {
  id           String      @id @default(cuid())
  nom          String
  prenom       String
  email        String      @unique
  code         String
  role         Role
  actif        Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  entrepriseId String?
  entreprise   Entreprise? @relation(fields: [entrepriseId], references: [id])

  commandesCreees     Commande[]   @relation("CommandeCreateur")
  commandesValidees   Commande[]   @relation("CommandeValidateur")
  commandesCommercial Commande[]   @relation("CommandeCommercial")
  commandesAchat      Commande[]   @relation("CommandeAchat")
  historiques         Historique[]
}

model SiteMontage {
  id        String     @id @default(cuid())
  nom       String
  adresse   String
  ville     String
  telephone String?
  actif     Boolean    @default(true)
  createdAt DateTime   @default(now())
  commandes Commande[]
}

model Commande {
  id              String         @id @default(cuid())
  reference       String         @unique
  statut          StatutCommande @default(DEMANDE_INSPECTION)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Véhicule
  typeVehicule    TypeVehicule
  immatriculation String
  numeroChauffeur String
  villeDepart     String

  // Inspection (rempli par agent commercial)
  dateInspection        DateTime?
  notesInspection       String?
  inspectionValideeAgent Boolean  @default(false)  // Agent client a validé l'inspection
  inspectionValideeN1    Boolean  @default(false)  // N+1 a validé l'inspection

  // Devis / Prix (rempli par agent commercial)
  prixTotal       Float?
  validePrix      Boolean        @default(false)

  // Point de montage (choisi par agent commercial lors du devis)
  siteMontageId   String?
  siteMontage     SiteMontage?   @relation(fields: [siteMontageId], references: [id])

  // Suivi livraison/montage
  dateLivraison   DateTime?
  dateMontage     DateTime?
  notesMontage    String?

  // Relations
  entrepriseId    String
  entreprise      Entreprise     @relation(fields: [entrepriseId], references: [id])
  createurId      String
  createur        Utilisateur    @relation("CommandeCreateur", fields: [createurId], references: [id])
  validateurId    String?
  validateur      Utilisateur?   @relation("CommandeValidateur", fields: [validateurId], references: [id])
  agentCommercialId String?
  agentCommercial   Utilisateur? @relation("CommandeCommercial", fields: [agentCommercialId], references: [id])
  serviceAchatId  String?
  serviceAchat    Utilisateur?   @relation("CommandeAchat", fields: [serviceAchatId], references: [id])

  pneus           Pneu[]
  historiques     Historique[]
}

model Pneu {
  id           String   @id @default(cuid())
  marque       String
  reference    String?
  dimension    String
  quantite     Int
  prixUnitaire Float                   // Prix HT
  disponible   Boolean  @default(true)
  notes        String?
  commandeId   String
  commande     Commande @relation(fields: [commandeId], references: [id], onDelete: Cascade)
}

model Historique {
  id            String         @id @default(cuid())
  statut        StatutCommande
  commentaire   String?
  createdAt     DateTime       @default(now())
  commandeId    String
  commande      Commande       @relation(fields: [commandeId], references: [id], onDelete: Cascade)
  utilisateurId String?
  utilisateur   Utilisateur?   @relation(fields: [utilisateurId], references: [id])
}
